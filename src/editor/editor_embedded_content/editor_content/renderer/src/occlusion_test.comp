#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

#define MAX_HIZ_LEVELS 16

struct OcclusionCandidate {
	vec4 worldMinPrevious;
	vec4 worldMaxPadding;
	vec4 screenRect;
	vec4 depthParams;
};

layout(binding = 0) readonly buffer Candidates {
	OcclusionCandidate candidates[];
};

layout(binding = 1) writeonly buffer Visibility {
	uint visible[];
};

layout(binding = 2) uniform OcclusionParams {
	mat4 view;
	mat4 projection;
	vec4 screenSizeCount;
	vec4 depthSizePadding;
};

layout(binding = 3) uniform sampler2D hizDepth[MAX_HIZ_LEVELS];

bool invalidVec4(vec4 v) {
	return any(isnan(v)) || any(isinf(v));
}

void markVisible(uint idx) {
	visible[idx] = 1u;
}

vec3 cornerFor(uint i, vec3 mn, vec3 mx) {
	return vec3(
		((i & 1u) == 0u) ? mn.x : mx.x,
		((i & 2u) == 0u) ? mn.y : mx.y,
		((i & 4u) == 0u) ? mn.z : mx.z);
}

void main() {
	uint idx = gl_GlobalInvocationID.x;
	uint candidateCount = uint(screenSizeCount.z);
	uint levelCount = uint(screenSizeCount.w);
	if (idx >= candidateCount) {
		return;
	}
	visible[idx] = 1u;
	if (levelCount == 0u || screenSizeCount.x <= 0.0 || screenSizeCount.y <= 0.0) {
		return;
	}

	OcclusionCandidate candidate = candidates[idx];
	vec3 mn = candidate.worldMinPrevious.xyz;
	vec3 mx = candidate.worldMaxPadding.xyz;
	vec2 rectMin = vec2(1.0);
	vec2 rectMax = vec2(0.0);
	float nearestDepth = 1.0;

	for (uint i = 0u; i < 8u; i++) {
		vec4 clip = projection * view * vec4(cornerFor(i, mn, mx), 1.0);
		if (invalidVec4(clip) || clip.w <= 0.0001) {
			markVisible(idx);
			return;
		}
		vec3 ndc = clip.xyz / clip.w;
		if (any(isnan(ndc)) || any(isinf(ndc)) || ndc.z < 0.0 || ndc.z > 1.0) {
			markVisible(idx);
			return;
		}
		vec2 uv = ndc.xy * 0.5 + 0.5;
		rectMin = min(rectMin, uv);
		rectMax = max(rectMax, uv);
		nearestDepth = min(nearestDepth, ndc.z);
	}

	if (rectMax.x <= 0.0 || rectMax.y <= 0.0 || rectMin.x >= 1.0 || rectMin.y >= 1.0) {
		markVisible(idx);
		return;
	}

	float pad = max(candidate.worldMaxPadding.w, 0.0);
	vec2 padUv = pad / max(screenSizeCount.xy, vec2(1.0));
	rectMin = clamp(rectMin - padUv, vec2(0.0), vec2(1.0));
	rectMax = clamp(rectMax + padUv, vec2(0.0), vec2(1.0));

	vec2 rectPixels = max((rectMax - rectMin) * screenSizeCount.xy, vec2(candidate.depthParams.y));
	float maxExtent = max(rectPixels.x, rectPixels.y);
	uint mip = uint(clamp(floor(log2(max(maxExtent, 1.0))) - 1.0, 0.0, float(levelCount - 1u)));
	vec2 center = (rectMin + rectMax) * 0.5;
	float sampledDepth = texture(hizDepth[mip], center).r;
	sampledDepth = max(sampledDepth, texture(hizDepth[mip], rectMin).r);
	sampledDepth = max(sampledDepth, texture(hizDepth[mip], vec2(rectMax.x, rectMin.y)).r);
	sampledDepth = max(sampledDepth, texture(hizDepth[mip], vec2(rectMin.x, rectMax.y)).r);
	sampledDepth = max(sampledDepth, texture(hizDepth[mip], rectMax).r);

	if (sampledDepth >= depthSizePadding.w || sampledDepth <= 0.0 || isnan(sampledDepth) || isinf(sampledDepth)) {
		markVisible(idx);
		return;
	}

	float bias = max(candidate.depthParams.x, 0.0);
	if (candidate.worldMinPrevious.w > 0.5) {
		bias *= 2.0;
	}
	visible[idx] = (nearestDepth <= sampledDepth + bias) ? 1u : 0u;
}
